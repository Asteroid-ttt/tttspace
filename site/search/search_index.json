{"config":{"lang":["zh","en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u9996\u9875","text":"ttt \u7684\u7b14\u8bb0\u672c <p>\u957f\u671f\u8bb0\u5f55\u8ba1\u7b97\u673a\u57fa\u7840\u3001\u5355\u7247\u673a\u3001\u5d4c\u5165\u5f0f Linux\u3001\u673a\u5668\u4eba\u4e0e AI \u5b66\u4e60\u3002</p> \u8ba1\u7b97\u673a\u57fa\u7840 \u5355\u7247\u673a \u5d4c\u5165\u5f0f Linux \u673a\u5668\u4eba AI \u9879\u76ee\u8bb0\u5f55 \u968f\u7b14 <p>\u4fdd\u6301\u9ad8\u9891\u8f93\u5165\uff0c\u8f93\u51fa\u7ed3\u6784\u5316\u7b14\u8bb0\u3002</p> Notebook \u5173\u4e8e\u8fd9\u4e2a\u7ad9\u70b9 <ul> <li>\u6309\u5de6\u4fa7\u5bfc\u822a\u8fdb\u5165\u5404\u4e13\u9898\u76ee\u5f55\u3002</li> <li>\u4f18\u5148\u8bb0\u5f55\u53ef\u590d\u7528\u7684\u65b9\u6cd5\u4e0e\u7ed3\u8bba\u3002</li> <li>\u6301\u7eed\u66f4\u65b0\uff0c\u91cd\u5728\u957f\u671f\u79ef\u7d2f\u3002</li> </ul> <p>\u8fd9\u91cc\u4e0d\u518d\u7ef4\u62a4\u56fa\u5b9a\u680f\u76ee\u6e05\u5355\uff0c\u907f\u514d\u9891\u7e41\u624b\u52a8\u4fee\u6539\u3002</p>"},{"location":"ai/","title":"AI","text":"<p>\u7528\u4e8e\u8bb0\u5f55\u673a\u5668\u5b66\u4e60\u3001\u6df1\u5ea6\u5b66\u4e60\u4e0e\u5de5\u7a0b\u5316\u90e8\u7f72\u5b66\u4e60\u8fc7\u7a0b\u3002</p>"},{"location":"computer-basics/","title":"\u8ba1\u7b97\u673a\u57fa\u7840","text":"<p>\u8fd9\u91cc\u8bb0\u5f55\u8ba1\u7b97\u673a\u57fa\u7840\u77e5\u8bc6\u4f53\u7cfb\uff0c\u6309\u4ee5\u4e0b\u65b9\u5411\u6574\u7406\uff1a</p> <ul> <li>\u8ba1\u7b97\u673a\u7cfb\u7edf</li> <li>\u8ba1\u7b97\u673a\u7f51\u7edc</li> <li>\u64cd\u4f5c\u7cfb\u7edf</li> </ul>"},{"location":"computer-basics/computer-networks/","title":"\u8ba1\u7b97\u673a\u7f51\u7edc","text":"<p>\u7528\u4e8e\u8bb0\u5f55\u7f51\u7edc\u5206\u5c42\u3001\u534f\u8bae\u6808\u3001\u8def\u7531\u4ea4\u6362\u4e0e\u7f51\u7edc\u6392\u969c\u76f8\u5173\u7b14\u8bb0\u3002</p>"},{"location":"computer-basics/computer-systems/","title":"\u8ba1\u7b97\u673a\u7cfb\u7edf","text":"<p>\u7528\u4e8e\u8bb0\u5f55\u8ba1\u7b97\u673a\u7ec4\u6210\u3001\u4f53\u7cfb\u7ed3\u6784\u4e0e\u6027\u80fd\u5206\u6790\u76f8\u5173\u7b14\u8bb0\u3002</p>"},{"location":"computer-basics/operating-systems/","title":"\u64cd\u4f5c\u7cfb\u7edf","text":"<p>\u7528\u4e8e\u8bb0\u5f55\u8fdb\u7a0b\u7ebf\u7a0b\u3001\u5185\u5b58\u7ba1\u7406\u3001\u6587\u4ef6\u7cfb\u7edf\u4e0e\u5e76\u53d1\u540c\u6b65\u76f8\u5173\u7b14\u8bb0\u3002</p>"},{"location":"embedded-linux/","title":"\u5d4c\u5165\u5f0f Linux","text":"<p>\u7528\u4e8e\u8bb0\u5f55\u4ea4\u53c9\u7f16\u8bd1\u3001\u9a71\u52a8\u5f00\u53d1\u3001\u8bbe\u5907\u6811\u4e0e\u7cfb\u7edf\u88c1\u526a\u76f8\u5173\u7b14\u8bb0\u3002</p>"},{"location":"essays/","title":"\u968f\u7b14","text":"<p>\u7528\u4e8e\u8bb0\u5f55\u5b66\u4e60\u601d\u8003\u3001\u6280\u672f\u89c2\u70b9\u4e0e\u9636\u6bb5\u603b\u7ed3\u3002</p>"},{"location":"mcu/","title":"\u5355\u7247\u673a","text":"<p>\u8fd9\u91cc\u6c47\u603b\u5355\u7247\u673a\u65b9\u5411\u5b66\u4e60\u5185\u5bb9\uff1a</p> <ul> <li>51 \u7cfb\u5217</li> <li>stm32 \u7cfb\u5217</li> <li>FreeRTOS</li> </ul>"},{"location":"mcu/freertos/","title":"FreeRTOS","text":"<p>\u6458\u8981</p> <p>\u8fd9\u7bc7\u6587\u7ae0\u662f\u5bf9 FreeRTOS \u5b66\u4e60\u7684\u5f15\u5165\uff0c\u4ecb\u7ecd\u4e86\u4e3a\u4ec0\u4e48\u9700\u8981\u4f7f\u7528RTOS\uff0c\u4ee5\u53ca RTOS \u7684\u8bbe\u8ba1\u7406\u5ff5\u3002</p>"},{"location":"mcu/freertos/#_1","title":"\u4e3b\u5faa\u73af","text":"<p>\u5f88\u591a\u4eba\u5199\u4ee3\u7801\u7ecf\u5e38\u4f1a\u4f7f\u7528\u8fd9\u6837\u7684\u5199\u6cd5\uff1a <pre><code>void vButtonTask()\n{\n\n}\n\nvoid vUartTask()\n{\n\n}\n\nvoid vAdcTask()\n{\n\n}\n\nvoid vTask(){\n    vButtonTask();\n    vUartTask();\n    vAdcTask();\n}\n\nint main(){\n\n    while(1){\n        vTask();\n    }\n}\n</code></pre></p> <p>\u8fd9\u662f\u4e00\u79cd\u987a\u5e8f\u7684\u5199\u6cd5\uff0c\u5728\u4e3b\u5faa\u73af\u4e2d\u5904\u7406\u3002\u8fd9\u6837\u80fd\u591f\u5b8c\u6210\u4efb\u52a1\u3002\u4f46\u662f\uff0c\u4e00\u65e6\u4efb\u52a1\u8017\u65f6\u8f83\u957f\uff08\u4e2d\u95f4\u6709Delay\uff0c\u6bd4\u5982\u6309\u952e\u7684\u5ef6\u65f6\u6d88\u6296\uff0c\u4e32\u53e3\u53d1\u9001\u7684\u963b\u585e\uff0cADC\u91c7\u6837\u7684\u8017\u65f6\uff09\u5c31\u4f1a\u9020\u6210\u76f8\u5e94\u4e0d\u7075\u654f\u7b49\u95ee\u9898\u3002</p>"},{"location":"mcu/freertos/#_2","title":"\u5b9a\u65f6\u5668\u4e2d\u65ad+\u4e3b\u5faa\u73af","text":"<p>\u8981\u6539\u8fdb\u8fd9\u79cd\u5199\u6cd5\uff0c\u53ef\u4ee5\u4f7f\u7528\u7ecf\u5178\u7684\u524d\u540e\u53f0\u7684\u5199\u6cd5\uff0c\u4f7f\u7528\u4e3b\u5faa\u73af\u52a0\u5b9a\u65f6\u5668\u4e2d\u65ad\u3002\u5c06\u65f6\u95f4\u8ba1\u6570\u653e\u5728\u5b9a\u65f6\u5668\u4e2d\u65ad\u91cc\uff0c\u6bcf\u96941ms\u4ea7\u751f\u4e00\u6b21\u4e2d\u65ad\u3002 - \u4e3a\u6bcf\u4e00\u4e2a\u4efb\u52a1\u5b9a\u4e49\u4e09\u4e2a\u53d8\u91cf\uff1a <code>task_cnt</code> <code>task_flag</code> <code>task_cnt_threshold</code> - \u5728\u5b9a\u65f6\u5668\u4e2d\u65ad\u4e2d\uff0c\u6bcf\u6b21\u8fdb\u5165\u4e2d\u65ad\u6309\u987a\u5e8f\u505a\u4e0b\u9762\u7684\u4e8b     - \u8ba1\u6570\u589e\u52a01 <code>task_cnt++</code>      - \u5224\u65ad\u662f\u5426\u5230\u8fbe\u9608\u503c\uff1a <code>if(task &gt;= threshold)</code>     - \u5982\u679c\u5230\u8fbe\u9608\u503c\uff0c\u5c06 <code>task_cnt = 0</code>\uff0c\u5e76\u4e14\u5c06 <code>task_flag = 1</code> \u63d0\u9192\u4efb\u52a1\u53ef\u4ee5\u5f00\u59cb\u4e86\u3002 - \u4efb\u52a1\u51fd\u6570\u653e\u5728\u4e3b\u5faa\u73af\u4e2d\uff0c\u6bcf\u6b21\u8fdb\u5165\u4efb\u52a1\u51fd\u6570\uff0c\u5224\u65ad <code>task_flag</code> \u662f\u5426\u4e3a1\uff0c\u5982\u679c\u4e3a1\uff0c\u5219\u6267\u884c\u4efb\u52a1\uff0c\u5e76\u4e14\u5728\u4efb\u52a1\u6700\u540e\u8bbe\u7f6e\u4e3a0\u3002</p> <p>\u7ecf\u8fc7\u4ee5\u4e0a\u7684\u6d41\u7a0b\uff0c\u5c31\u80fd\u591f\u5b9e\u73b0\u4e00\u4e2a\u4efb\u52a1\u6bcf\u9694\u4e00\u6bb5\u65f6\u95f4\u6267\u884c\u4e00\u6b21\u3002\u8fd9\u662f\u6211\u5728\u5199\u88f8\u673a\u9879\u76ee\u7684\u65f6\u5019\u6700\u5e38\u7528\u7684\u5199\u6cd5\u3002</p> <p>\u53ea\u662f\u8fd9\u79cd\u5199\u6cd5\u8fd8\u662f\u5b58\u5728\u7f3a\u70b9\uff0c\u5982\u679c\u4efb\u52a1\u672c\u8eab\u5c31\u4f1a\u82b1\u8d39\u4e0d\u5c11\u65f6\u95f4\uff08\u6bd4\u5982ADC\u91c7\u6837\u65f6\u95f4\u8f83\u957f\uff09\uff0c\u90a3\u4e48\u8fd9\u4e2a\u95ee\u9898\u4f9d\u65e7\u6ca1\u6cd5\u89e3\u51b3\u3002\u5728\u5927\u5bb6 flag \u90fd\u4e3a1\u7684\u60c5\u51b5\u4e0b\u4f9d\u7136\u9700\u8981\u6392\u961f\u7b49\u5f85\u90a3\u4e2a\u65f6\u95f4\u957f\u7684\u4efb\u52a1\u5148\u6267\u884c\u3002\u90a3\u4e48\u6309\u952e\u7684\u53cd\u5e94\u4f9d\u65e7\u4f1a\u53d8\u6162\uff08\u4f46\u662f\u6bd4\u4e4b\u524d\u597d\uff09\u3002</p>"},{"location":"mcu/freertos/#_3","title":"\u64cd\u4f5c\u7cfb\u7edf\u7684\u5f15\u5165","text":"<p>\u5982\u4f55\u89e3\u51b3\u8fd9\u4e2a\u95ee\u9898\uff0c\u5c31\u8981\u5f15\u51fa\u64cd\u4f5c\u7cfb\u7edf\u7684\u8bbe\u8ba1\u7406\u5ff5\uff1a</p> <p>\u64cd\u4f5c\u7cfb\u7edf\u7684\u7406\u5ff5</p> <ul> <li>\u65f6\u95f4\u7247\u8f6e\u8f6c\uff1a\u5bf9\u4e8e\u76f8\u540c\u4f18\u5148\u7ea7\u4efb\u52a1\uff0c\u4ea4\u66ff\u6267\u884c\uff08\u5e76\u53d1\uff09\u3002\u8fd9\u6837\u4e0d\u4f1a\u51fa\u73b0\u50cf\u6309\u952e\u90a3\u6837\u8017\u65f6\u77ed\u7684\u4efb\u52a1\u88ab\u8017\u65f6\u957f\u7684\u4efb\u52a1\u963b\u585e\u8fd9\u79cd\u4e8b\u60c5\u3002</li> <li>\u62a2\u5360\u5f0f\u8c03\u5ea6\uff1a\u5bf9\u4e8e\u4e0d\u540c\u4f18\u5148\u7ea7\u7684\u4efb\u52a1\uff0c\u9ad8\u4f18\u5148\u7ea7\u4efb\u52a1\u80fd\u6253\u65ad\u4f4e\u4f18\u5148\u7ea7\u7684\u4efb\u52a1\u3002</li> </ul> <p>\u4f7f\u7528 FreeRTOS \u4e4b\u540e\uff0c\u5c31\u4f1a\u53d1\u73b0ADC\uff08\u7b49\u6548\u4e8edelay\uff09\u4e0d\u4f1a\u5728\u4e3b\u5faa\u73af\u4e2d\u963b\u585e\u5176\u4ed6\u4efb\u52a1\uff0c\u4e32\u53e3\u6253\u5370\u65f6\u95f4\u65f6\u95f4\u4e5f\u57fa\u672c\u51c6\u786e\u3002\u4f46\u662f\u5982\u4f55\u8ba9\u65f6\u95f4\u66f4\u51c6\u786e\u5462\uff1f</p> <p>\u8fd9\u91cc\u63d0\u4f9b\u4e00\u79cd\u65b9\u6cd5\uff1a <pre><code>void vUartTask()\n{\n    uint32_t ulBeginTime;  //ul \u6307\u7684\u662f unsigned long\n\n    // 1. \u83b7\u53d6\u4efb\u52a1\u5f00\u59cb\u65f6\u523b\n    ulBeginTime = HAL_GetTick();\n\n    // 2. \u6267\u884c\u4e32\u53e3\u6253\u5370\n    printf(\"uart time:%d \\n\\r\", HAL_GetTick());\n\n    // 3. \u5ef6\u65f6\u5230 ulBeginTime + 1000ms \u65f6\u523b\n    vTaskDelayUntil(&amp;ulBeginTime, 1000);\n}\n</code></pre></p> <p>\u4f7f\u7528\u8fd9\u79cd\u65b9\u5f0f\u5c31\u53ef\u4ee5\u7cbe\u786e\u7684\u5ef6\u65f6\u4e00\u6bb5\u65f6\u95f4\uff0c\u800c\u4e0d\u4f1a\u88ab\u4efb\u52a1\u6267\u884c\u7684\u65f6\u95f4\u6240\u5e72\u6270\u3002</p> <p>\u53c2\u8003\u89c6\u9891</p> <p>\u3010\u3010\u6c5f\u79d1\u5927\u3011\u6c5f\u79d1\u5927\u8001\u5b66\u957f\u5e26\u4f60 FreeRTOS \u5de5\u7a0b\u9879\u76ee\u5b9e\u8df5\u3011https://www.bilibili.com/video/BV1nvqSBAELQ</p>"},{"location":"mcu/mcs51/","title":"51 \u7cfb\u5217","text":"<p>\u7528\u4e8e\u8bb0\u5f55 51 \u5355\u7247\u673a\u57fa\u7840\u3001\u5916\u8bbe\u9a71\u52a8\u4e0e\u5b9e\u9a8c\u7b14\u8bb0\u3002</p>"},{"location":"mcu/stm32/","title":"stm32 \u7cfb\u5217","text":"<p>\u7528\u4e8e\u8bb0\u5f55 stm32 \u5916\u8bbe\u3001\u9a71\u52a8\u6846\u67b6\u4e0e\u8c03\u8bd5\u7ecf\u9a8c\u3002</p>"},{"location":"projects/","title":"\u9879\u76ee\u8bb0\u5f55","text":"<p>\u7528\u4e8e\u6c89\u6dc0\u9879\u76ee\u9636\u6bb5\u590d\u76d8\u3001\u6280\u672f\u9009\u578b\u4e0e\u5173\u952e\u95ee\u9898\u89e3\u51b3\u65b9\u6848\u3002</p>"},{"location":"robotics/","title":"\u673a\u5668\u4eba","text":"<p>\u7528\u4e8e\u8bb0\u5f55\u8fd0\u52a8\u63a7\u5236\u3001\u4f20\u611f\u5668\u878d\u5408\u3001\u8def\u5f84\u89c4\u5212\u4e0e\u673a\u5668\u4eba\u7cfb\u7edf\u5b9e\u8df5\u3002</p>"}]}